# TubeAPI Configuration

# Required: Basic Auth credentials
TUBEAPI_USER=admin
TUBEAPI_PASS=changeme

# Optional: Server configuration
TUBEAPI_PORT=8000

# Optional: File management
TUBEAPI_TEMP_DIR=/tmp/tubeapi
TUBEAPI_CLEANUP_MAX_AGE=7200

# Required: Supabase Storage
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-semcret-key
SUPABASE_BUCKET=yt-stock
